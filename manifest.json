{
  "manifest_version": 3,
  "name": "Claude Prompt Runner",
  "description": "Auto-send prompts to Claude with region substitution",
  "version": "4.0.1",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "clipboardWrite", "clipboardRead", "alarms"],
  "host_permissions": ["https://claude.ai/*", "https://discord.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
